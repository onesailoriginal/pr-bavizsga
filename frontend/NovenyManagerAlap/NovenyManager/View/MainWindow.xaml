<Window x:Class="NovenyManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NovenyManager" xmlns:view="clr-namespace:NovenyManager.View"
        mc:Ignorable="d"
        Title="Növény Nyilvántartó" Height="600" Width="950">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Novenyek}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <view:NovenyDisplay/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

        <StackPanel Grid.Column="1">
            <Label FontWeight="Bold" Content="Új növény hozzáadása"/>
            <Label Content="Név:"/>
            <TextBox Text="{Binding UjNev}" />

            <Label Content="Faj:"/>
            <TextBox Text="{Binding UjFaj}" />

            <Label Content="Locsolási időköz (nap):"/>
            <TextBox Text="{Binding UjLocsolasiIdoKoz}" />
            <Button Content="Hozzáadás" Command="{Binding NovenyHozzaadCommand}"/>
        </StackPanel>
        
    </Grid>
</Window>
